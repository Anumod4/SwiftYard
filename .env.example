# SwiftYard API Environment Configuration
# Copy this file to .env.local and update with your values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# API Server Port (default: 4000)
PORT=4000

# =============================================================================
# DATABASE CONFIGURATION (Turso)
# =============================================================================

# Turso Database URL
# Format: libsql://<your-db-url> or https://<your-db-url>
TURSO_DB_URL=libsql://swiftyard-anumodk.aws-ap-northeast-1.turso.io

# Turso Authentication Token
# Get this from your Turso dashboard
TURSO_AUTH_TOKEN=your-turso-auth-token

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=


# JWT Secret Key for token signing
# IMPORTANT: Change this to a strong random string in production!
JWT_SECRET=swiftyard-secret-key-change-in-production

# JWT Token Expiration (default: 7d)
JWT_EXPIRATION=7d

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed origins for CORS (comma-separated)
# Use '*' for development, specify domains for production
CORS_ORIGINS=https://swiftyard.netlify.app,http://localhost:3000,http://localhost:4000

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================

# Google Drive API Client ID (for document storage)
GOOGLE_DRIVE_CLIENT_ID=

# WhatsApp Business API Configuration (for notifications)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# Choose ONE provider: SendGrid OR SMTP

# SendGrid (recommended - simpler setup)
# SENDGRID_API_KEY=your-sendgrid-api-key

# OR SMTP (any email provider - Gmail, Outlook, Ethereal, Mailtrap, etc.)
# SMTP_HOST=smtp.ethereal.email
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Sender email address
FROM_EMAIL=noreply@yourdomain.com

# Application URL for email links
APP_URL=https://swiftyard.netlify.app

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# API Base URL for frontend client
# Leave empty for default (http://localhost:4000/api in dev)
VITE_API_URL=

# Gemini API Key (for AI features if used)
GEMINI_API_KEY=

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================

# Node Environment
NODE_ENV=development

# Enable/Disable request logging
ENABLE_REQUEST_LOGGING=true

# Enable/Disable error stack traces in responses (disable in production)
SHOW_ERROR_STACKS=false
