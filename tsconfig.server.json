{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "outDir": "./dist-server",
        "rootDir": ".",
        "strict": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true
    },
    "include": [
        "server/**/*",
        "turso.ts",
        "types.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "dist-server",
        "src/**/*",
        "*.config.*"
    ]
}