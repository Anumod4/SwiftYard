meta {
  name: Save Role
  type: http
  seq: 2
}

post {
  url: "http://localhost:4000/api/admin/roles/save"
  auth: bearer
}

body {
  type: json
  json: {
    "name": "Admin",
    "description": "Administrator role",
    "permissions": ["read", "write", "delete"],
    "accessLevels": ["all"]
  }
}

headers {
  X-Facility-ID: {{facilityId}}
}
