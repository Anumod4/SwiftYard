meta {
  name: Create Webhook
  type: http
  seq: 2
}

post {
  url: "{{baseUrl}}/api/webhooks"
  body: json
  auth: bearer
}

body:json {
  name: "My Webhook"
  url: "https://httpbin.org/post"
  events: ["appointment.created", "appointment.updated", "trailer.created"]
  secret: "my-secret-key"
}

tests {
  const json = res.getBody();
  if (json.success && json.data) {
    bru.setVar('webhookId', json.data.id);
  }
}

headers {
  X-Facility-ID: {{facilityId}}
}
