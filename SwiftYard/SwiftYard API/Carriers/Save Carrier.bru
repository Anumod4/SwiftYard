meta {
  name: Save Carrier
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/carriers/save
  body: json
  auth: bearer
}

headers {
  X-Facility-ID: {{facilityId}}
}

auth:bearer {
  token: {{Token}}
}

